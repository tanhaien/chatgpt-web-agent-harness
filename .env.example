# Copy to .env or set these in your shell before `npm start`.
# (.env is gitignored — never commit real values.)

# MCP server port
PORT=8787
# Bind address (keep loopback)
AGENT_HOST=127.0.0.1

# REQUIRED: folder the agent may read/write
AGENT_WORKSPACE=C:\path\to\your\repo
# Optional extra roots, semicolon-separated
AGENT_EXTRA_ROOTS=
# Optional extra roots as JSON. Prefer this when paths contain ':' or ';'.
# AGENT_EXTRA_ROOTS_JSON=["C:\\path\\one","D:\\path\\two"]

# safe (recommended) | full
AGENT_MODE=safe
# strict (read-only) | balanced (risky actions require local approval) | full
AGENT_POLICY=balanced
# Set to 1 only if you really want catastrophic system commands allowed
# AGENT_ALLOW_DANGEROUS=1

# Optional bearer token. If set, /mcp requires: Authorization: Bearer <token>
MCP_AUTH_TOKEN=
# Optional comma-separated browser origins. Empty rejects browser-origin MCP calls.
MCP_ALLOWED_ORIGINS=
# Optional operator secret for MCP-based approval. Prefer the local dashboard.
AGENT_APPROVAL_TOKEN=

# Local-only metrics dashboard (0 disables). Do NOT use 8788 (OpenAI tunnel uses it).
DASHBOARD_PORT=8790
